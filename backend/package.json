{
  "name": "cado-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --outdir=dist --platform=node --target=node20 --format=esm --packages=external --sourcemap",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "npm run db:generate && npm run db:migrate"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@fastify/cors": "^10.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "9.3.0",
    "@fastify/swagger": "9.6.1",
    "ai": "^4.3.16",
    "better-auth": "1.4.5",
    "cloudinary": "^2.6.1",
    "drizzle-orm": "0.44.7",
    "fastify": "5.7.1",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "drizzle-kit": "0.31.5",
    "esbuild": "0.27.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
