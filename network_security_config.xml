
<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow all cleartext (HTTP) traffic for development -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system certificates -->
            <certificates src="system" />
            <!-- Trust user-added certificates (for debugging with proxies) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Specific domain configurations for Specular backend -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">specular.dev</domain>
        <domain includeSubdomains="true">app.specular.dev</domain>
        <domain includeSubdomains="true">cloudflare.com</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
